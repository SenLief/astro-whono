---
import AdminLayout from '../../components/admin/AdminLayout.astro';
import AdminShell from '../../components/admin/AdminShell.astro';
import { createWithBase } from '../../utils/format';

const isDev = import.meta.env.DEV;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const adminStylesHref = isDev ? (await import('../../styles/components/admin.css?url')).default : null;
---

<AdminLayout title="Admin Console" stylesHref={adminStylesHref}>
  <AdminShell
    currentRoute="overview"
    title="Admin Console"
    subtitle="后台概览"
    description="Phase 0 先把后台从单页 Theme Console 收口为真实路由壳层：`/admin/` 负责稳定入口，`/admin/theme/` 承担现有主题配置工作流。"
    modeLabel={isDev ? 'DEV 可写' : '只读模式'}
    modeHint={isDev ? '当前后台仍以本地文件与 Git 为真相来源；生产环境继续保持只读。' : '当前环境仅保留后台入口与只读说明，不提供写入能力。'}
  >
    <section class="admin-overview">
      <div class="admin-overview__grid">
        <article class="admin-overview-card">
          <p class="admin-overview-card__eyebrow">Ready Now</p>
          <h2 class="admin-overview-card__title">Theme Console</h2>
          <p class="admin-overview-card__body">
            现有 `site / shell / home / page / ui` 设置继续沿用既有 bootstrap、校验、`dryRun`、`revision` 冲突保护与事务写盘链路。
          </p>
          <p class="admin-overview-card__meta">稳定子入口：`/admin/theme/`</p>
          <div class="admin-overview-card__actions">
            <a class="admin-btn admin-btn--muted" href={withBase('/admin/theme/')}>{isDev ? '进入 Theme Console' : '查看只读子入口'}</a>
          </div>
        </article>

        <article class="admin-overview-card">
          <p class="admin-overview-card__eyebrow">Phase 0</p>
          <h2 class="admin-overview-card__title">路由壳层已独立</h2>
          <p class="admin-overview-card__body">
            后台导航、稳定入口与 Theme 子路由已经拆开，后续 `Content / Media / Checks / Data` 会在真实能力落地后再追加页面，而不是先铺空壳。
          </p>
          <ul class="admin-overview-card__list">
            <li>保留 `/admin/` 作为后台稳定入口</li>
            <li>保留 `/api/admin/settings/` 现有契约</li>
            <li>继续限制为 DEV-only 可写后台</li>
          </ul>
        </article>

        <article class="admin-overview-card">
          <p class="admin-overview-card__eyebrow">Dirty Guard</p>
          <h2 class="admin-overview-card__title">页面切换会显式提醒</h2>
          <p class="admin-overview-card__body">
            `/admin/theme/` 的未保存状态不再只依赖浏览器离页提示；点击后台内部导航切换时，也会先确认是否放弃当前改动。
          </p>
        </article>

        <article class="admin-overview-card">
          <p class="admin-overview-card__eyebrow">Readonly Boundary</p>
          <h2 class="admin-overview-card__title">生产环境只保留结构，不开放写入</h2>
          <p class="admin-overview-card__body">
            preview / production 下仍然不提供后台写接口；本次只新增真实页面结构、路由排除规则和对应的边界检查。
          </p>
        </article>
      </div>
    </section>
  </AdminShell>
</AdminLayout>

